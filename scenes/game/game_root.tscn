text = "Game host"

[node name="Description" type="Label" parent="GameView"]
layout_mode = 2
text = "Replace this panel with the project's gameplay scene. Pause: Escape. Debug: F1/F2/F3."

[node name="PauseMenu" type="VBoxContainer" parent="."]
