# Local development environment.
# Copy this file to .env and fill in real values.
# .env is gitignored; never commit secrets.
#
# Running the default GUT suite (or tools/setup_local.gd) reads these values
# and regenerates override.cfg so analytics keys stay in one place.
# Values in .env take precedence over shell environment variables locally.

ITCH_DEPLOY_ENABLED=true

# itch target as user/game (lowercase). Required for the deploy workflow gate.
ITCH_PROJECT=user/game

# butler API key with access to the itch project.
BUTLER_API_KEY=

# GameAnalytics credentials. Also written into override.cfg automatically.
GAMEANALYTICS_GAME_KEY=
GAMEANALYTICS_SECRET_KEY=
